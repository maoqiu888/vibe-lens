{
  "manifest_version": 3,
  "name": "Vibe-Lens",
  "version": "1.5.0",
  "description": "划词即鉴 · 你的审美雷达",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "assets/icon.svg"
  }
}
